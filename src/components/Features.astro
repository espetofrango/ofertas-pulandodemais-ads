---

<section class="features" id="catalogo">
  <div class="container">
    <div class="features-header">
      <span class="features-badge">🎮 Catálogo de Jogos</span>
      <h2 class="section-title features-title">
        Jogos & Eletrônicos <span class="highlight">para sua Festa</span>
      </h2>
      <p class="section-subtitle features-subtitle">
        Confira nossas mesas de jogos e atrações eletrônicas. Todos com entrega e montagem no Rio de Janeiro.
      </p>
    </div>

    <div class="games-grid">
      {games.map((game, index) => (
        <div class="game-card animate-on-scroll" style={`--index: ${index}`}>
          <div class="game-image-wrapper">
            <img src={game.image} alt={game.name} loading="lazy" width="400" height="300" />
            <span class="game-icon">{game.icon}</span>
          </div>
          <div class="game-info">
            <h3 class="game-name">{game.name}</h3>
            <p class="game-desc">{game.description}</p>
            <div class="game-footer">
              <div class="game-promo-badge">CONDIÇÃO ESPECIAL FERIADO</div>
              <a
                href="https://wa.me/5521964370625?text=Ol%C3%A1!%20Vi%20a%20oferta%20do%20Feriado%20de%201%20de%20Maio%20e%20gostaria%20de%20consultar%20a%20disponibilidade."
                target="_blank"
                rel="noopener noreferrer"
                class="game-cta"
                aria-label={`Consultar valor de ${game.name}`}
              >
                CONSULTAR VALOR E DISPONIBILIDADE
              </a>
              <span class="game-response-note">Resposta imediata!</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="features-note animate-on-scroll">
      <p>⚡ <strong>Todos os brinquedos</strong> incluem entrega, montagem e desmontagem. Período padrão de locação: <strong>4/5 horas de festa ou a combinar.</strong></p>
      <p class="no-stairs-warning">⚠️ <strong>Não transportamos por escada.</strong></p>
      <p>🔌 Jogos eletrônicos necessitam de ponto de energia elétrica (110V ou 220V). É necessário local coberto abrigado da chuva e do sol para a montagem. Consulte na reserva.</p>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const index = parseInt(el.style.getPropertyValue('--index') || '0');
          setTimeout(() => {
            el.classList.add('visible');
          }, index * 80);
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll('.features .animate-on-scroll').forEach((el) => {
    observer.observe(el);
  });
</script>

<style>
  .features {
    padding: var(--section-padding) 0;
    background: var(--color-bg-section);
    position: relative;
  }

  .features-header {
    text-align: center;
    margin-bottom: 56px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .features-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 18px;
    border-radius: 100px;
    background: rgba(0, 115, 207, 0.08);
    color: var(--color-primary);
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 16px;
    border: 1px solid rgba(0, 115, 207, 0.15);
  }

  .features-title {
    color: var(--color-text);
  }

  .features-title .highlight {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .features-subtitle {
    margin: 0 auto;
  }

  .games-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .game-card {
    background: var(--color-bg);
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition: all 0.4s ease;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  }

  .game-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 40px rgba(0, 115, 207, 0.15);
    border-color: var(--color-primary);
  }

  .game-image-wrapper {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4/3;
  }

  .game-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .game-card:hover .game-image-wrapper img {
    transform: scale(1.05);
  }

  .game-icon {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(8px);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .game-info {
    padding: 20px;
  }

  .game-name {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--color-text);
  }

  .game-desc {
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 16px;
    white-space: pre-line;
  }

  .game-footer {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: stretch;
  }

  .game-promo-badge {
    font-size: 11px;
    font-weight: 800;
    color: var(--color-danger);
    text-transform: uppercase;
    letter-spacing: 1px;
    background: rgba(227, 6, 19, 0.08);
    padding: 4px 12px;
    border-radius: 4px;
    text-align: center;
    border: 1px dashed var(--color-danger);
  }

  .game-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 14px 20px;
    background: #25D366;
    color: white;
    border-radius: var(--radius-sm);
    font-size: 13px;
    font-weight: 800;
    transition: all 0.3s ease;
    text-align: center;
    box-shadow: 0 4px 12px rgba(37, 211, 102, 0.2);
  }

  .game-cta:hover {
    background: #20BA5C;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(37, 211, 102, 0.4);
  }

  .game-response-note {
    font-size: 12px;
    color: #25D366;
    font-weight: 600;
    text-align: center;
    display: block;
    margin-top: -4px;
  }

  .features-note {
    margin-top: 48px;
    padding: 24px 32px;
    background: rgba(0, 115, 207, 0.04);
    border: 1px solid rgba(0, 115, 207, 0.1);
    border-radius: var(--radius);
    text-align: center;
  }

  .features-note p {
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  .features-note p + p {
    margin-top: 4px;
  }

  .no-stairs-warning {
    display: inline-block;
    margin-top: 16px;
    padding: 10px 24px;
    background: rgba(227, 6, 19, 0.08);
    border: 1px solid var(--color-danger);
    color: var(--color-danger);
    border-radius: var(--radius-sm);
    font-size: 15px;
  }

  @media (max-width: 1024px) {
    .games-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .games-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .game-info {
      padding: 16px;
    }
  }
</style>
