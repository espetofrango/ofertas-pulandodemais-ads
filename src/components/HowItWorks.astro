---
// arquivo: src/components/HowItWorks.astro

const steps = [
  {
    number: '01',
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="4" y="8" width="32" height="24" rx="4" stroke="white" stroke-width="2"/><path d="M12 20h8M12 24h16M12 16h16" stroke="white" stroke-width="1.5" stroke-linecap="round"/><circle cx="30" cy="16" r="2" fill="#FFD400"/></svg>`,
    title: 'Escolha os Jogos',
    description: 'Navegue pelo nosso catálogo de mesas de jogos e eletrônicos. Monte o pacote ideal para sua festa!',
  },
  {
    number: '02',
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 32V12a4 4 0 014-4h16a4 4 0 014 4v20" stroke="white" stroke-width="2"/><path d="M14 16h12M14 20h8M14 24h10" stroke="white" stroke-width="1.5" stroke-linecap="round"/><circle cx="28" cy="28" r="6" fill="#FFD400" stroke="white" stroke-width="2"/><path d="M26 28l1.5 1.5L30 26" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'Faça seu Orçamento',
    description: 'Envie pelo WhatsApp e receba o orçamento detalhado em minutos. Rápido, fácil e sem complicação!',
  },
  {
    number: '03',
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20 6l4 8h8l-6.5 5 2.5 9L20 23l-8 5 2.5-9L8 14h8l4-8z" fill="#FFD400" stroke="white" stroke-width="1.5"/></svg>`,
    title: 'Festa Garantida!',
    description: 'Entregamos, montamos e cuidamos de tudo no dia do evento. É só curtir a diversão!',
  },
];
---

<section class="how-it-works" id="como-funciona">
  <div class="container">
    <div class="hiw-header">
      <span class="hiw-badge">✨ Simples e Rápido</span>
      <h2 class="section-title hiw-title">Como Funciona</h2>
      <p class="section-subtitle hiw-subtitle">
        Em 3 passos simples, sua festa estará pronta para a diversão!
      </p>
    </div>

    <div class="steps-container">
      <div class="steps-line">
        <svg class="line-svg" preserveAspectRatio="none">
          <line x1="0" y1="50%" x2="100%" y2="50%" class="dashed-line" />
        </svg>
      </div>

      {steps.map((step, index) => (
        <div class="step animate-on-scroll" style={`--index: ${index}`}>
          <span class="step-bg-number">{step.number}</span>
          <div class="step-icon" set:html={step.icon} />
          <h3 class="step-title">{step.title}</h3>
          <p class="step-desc">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const observer2 = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const index = parseInt(el.style.getPropertyValue('--index') || '0');
          setTimeout(() => {
            el.classList.add('visible');
          }, index * 200);
          observer2.unobserve(el);
        }
      });
    },
    { threshold: 0.2 }
  );

  document.querySelectorAll('.how-it-works .animate-on-scroll').forEach((el) => {
    observer2.observe(el);
  });

  // Animate line
  const lineObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('line-visible');
          lineObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.3 }
  );

  const lineSvg = document.querySelector('.steps-line');
  if (lineSvg) lineObserver.observe(lineSvg);
</script>

<style>
  .how-it-works {
    padding: var(--section-padding) 0;
    background: linear-gradient(180deg, #FFFFFF 0%, #F0F7FF 100%);
    position: relative;
    overflow: hidden;
  }

  .hiw-header {
    text-align: center;
    margin-bottom: 64px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hiw-badge {
    display: inline-flex;
    padding: 6px 18px;
    border-radius: 100px;
    background: rgba(0, 115, 207, 0.08);
    color: var(--color-primary);
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 16px;
    border: 1px solid rgba(0, 115, 207, 0.12);
  }

  .hiw-title {
    color: var(--color-text);
  }

  .hiw-subtitle {
    margin: 0 auto;
  }

  .steps-container {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    position: relative;
  }

  .steps-line {
    position: absolute;
    top: 80px;
    left: 16%;
    right: 16%;
    height: 2px;
    z-index: 0;
  }

  .line-svg {
    width: 100%;
    height: 2px;
  }

  .dashed-line {
    stroke: var(--color-primary);
    stroke-width: 2;
    stroke-dasharray: 8 6;
    stroke-dashoffset: 500;
    transition: stroke-dashoffset 2s ease;
  }

  .line-visible .dashed-line {
    stroke-dashoffset: 0;
  }

  .step {
    position: relative;
    text-align: center;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .step-bg-number {
    position: absolute;
    top: -20px;
    font-family: var(--font-display);
    font-size: 100px;
    font-weight: 800;
    color: var(--color-primary);
    opacity: 0.06;
    line-height: 1;
    pointer-events: none;
    z-index: -1;
  }

  .step-icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(0, 115, 207, 0.25);
  }

  .step-title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    color: var(--color-text);
  }

  .step-desc {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 300px;
  }

  @media (max-width: 768px) {
    .steps-container {
      grid-template-columns: 1fr;
      gap: 48px;
      padding-left: 48px;
    }

    .steps-line {
      top: 0;
      bottom: 0;
      left: 24px;
      right: auto;
      width: 2px;
      height: 100%;
    }

    .line-svg {
      width: 2px;
      height: 100%;
    }

    .dashed-line {
      x1: 1;
      y1: 0;
      x2: 1;
      y2: 100%;
    }

    .step {
      text-align: left;
      align-items: flex-start;
    }

    .step-bg-number {
      left: -48px;
      top: 0;
      font-size: 56px;
    }
  }
</style>
