---
// arquivo: src/components/Pricing.astro

const plans = [
  {
    name: 'Básico',
    emoji: '🎯',
    price: 'A partir de',
    amount: 'R$ 347',
    period: '/mesa',
    description: 'Perfeito para uma diversão pontual',
    features: [
      { text: '1 mesa de jogo à sua escolha', included: true },
      { text: 'Entrega e montagem', included: true },
      { text: '4 horas de evento', included: true },
      { text: 'Jogos eletrônicos', included: false },
      { text: 'Desconto por combo', included: false },
    ],
    cta: 'Solicitar',
    ctaLink: 'https://wa.me/5521964370625?text=Ol%C3%A1!%20Vi%20a%20oferta%20do%20Feriado%20de%201%20de%20Maio%20e%20gostaria%20de%20consultar%20a%20disponibilidade.',
    featured: false,
  },
  {
    name: 'Combo Jogos',
    emoji: '⭐',
    price: 'Melhor custo',
    amount: 'Consulte',
    period: '/pacote',
    description: 'O combo mais procurado para festas',
    badge: 'Mais Popular',
    features: [
      { text: '3 mesas de jogos à escolha', included: true },
      { text: 'Entrega e montagem', included: true },
      { text: '4 horas de evento', included: true },
      { text: 'Mix com jogos eletrônicos', included: true },
      { text: 'Desconto especial no combo', included: true },
    ],
    cta: 'Montar Pacote',
    ctaLink: 'https://wa.me/5521964370625?text=Ol%C3%A1!%20Vi%20a%20oferta%20do%20Feriado%20de%201%20de%20Maio%20e%20gostaria%20de%20consultar%20a%20disponibilidade.',
    featured: true,
  },
  {
    name: 'Mega Evento',
    emoji: '🏆',
    price: 'Personalizado',
    amount: 'Sob consulta',
    period: '',
    description: 'Para grandes eventos e empresas',
    features: [
      { text: '5+ atrações de jogos', included: true },
      { text: 'Entrega e montagem', included: true },
      { text: 'Horário estendido', included: true },
      { text: 'Equipe completa de monitores', included: true },
      { text: 'Todos os eletrônicos', included: true },
      { text: 'Atendimento dedicado', included: true },
    ],
    cta: 'Falar com Consultor',
    ctaLink: 'https://wa.me/5521964370625?text=Ol%C3%A1!%20Vi%20a%20oferta%20do%20Feriado%20de%201%20de%20Maio%20e%20gostaria%20de%20consultar%20a%20disponibilidade.',
    featured: false,
  },
];
---

<section class="pricing" id="pacotes">
  <div class="container">
    <div class="pricing-header">
      <span class="pricing-badge">💰 Pacotes & Preços</span>
      <h2 class="section-title pricing-title">
        Escolha o Pacote <span class="highlight">Ideal</span>
      </h2>
      <p class="section-subtitle pricing-subtitle">
        Sabemos que feriado no Rio é dia de reunir a família e as crianças. Não perca tempo montando nada: nós levamos, montamos e garantimos a alegria. Confira nossa tabela especial de jogos abaixo e faça sua reserva agora mesmo pelo WhatsApp!
      </p>
    </div>

    <div class="pricing-grid">
      {plans.map((plan, index) => (
        <div class={`pricing-card ${plan.featured ? 'featured' : ''} animate-on-scroll`} style={`--index: ${index}`}>
          {plan.badge && <span class="pricing-card-badge">{plan.badge}</span>}
          
          <div class="pricing-card-header">
            <span class="plan-emoji">{plan.emoji}</span>
            <h3 class="plan-name">{plan.name}</h3>
            <p class="plan-description">{plan.description}</p>
          </div>

          <div class="pricing-card-promo">
            <span class="promo-badge">CONDIÇÃO ESPECIAL FERIADO</span>
          </div>

          <ul class="plan-features">
            {plan.features.map((feature) => (
              <li class={feature.included ? 'included' : 'excluded'}>
                <span class="feature-icon">{feature.included ? '✓' : '✗'}</span>
                {feature.text}
              </li>
            ))}
          </ul>

          <a
            href={plan.ctaLink}
            target="_blank"
            rel="noopener noreferrer"
            class="pricing-cta"
            aria-label={`${plan.cta} - ${plan.name}`}
          >
            CONSULTAR VALOR E DISPONIBILIDADE
          </a>
          <span class="pricing-response-note">Resposta imediata!</span>
        </div>
      ))}
    </div>

    <div class="pricing-info animate-on-scroll" style="--index: 3">
      <p>📋 <strong>Período padrão:</strong> 4 horas de evento · <strong>Frete:</strong> varia conforme o bairro (consulte)</p>
      <p>🔌 Jogos eletrônicos necessitam de ponto de energia (110V ou 220V)</p>
    </div>
  </div>
</section>

<script>
  const observer4 = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const index = parseInt(el.style.getPropertyValue('--index') || '0');
          setTimeout(() => {
            el.classList.add('visible');
          }, index * 150);
          observer4.unobserve(el);
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll('.pricing .animate-on-scroll').forEach((el) => {
    observer4.observe(el);
  });
</script>

<style>
  .pricing {
    padding: var(--section-padding) 0;
    background: var(--color-bg-section);
    position: relative;
  }

  .pricing-header {
    text-align: center;
    margin-bottom: 56px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .pricing-badge {
    display: inline-flex;
    padding: 6px 18px;
    border-radius: 100px;
    background: rgba(0, 115, 207, 0.08);
    color: var(--color-primary);
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 16px;
    border: 1px solid rgba(0, 115, 207, 0.15);
  }

  .pricing-title .highlight {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: center;
  }

  .pricing-card {
    position: relative;
    padding: 36px 28px;
    background: var(--color-bg);
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    transition: all 0.4s ease;
    display: flex;
    flex-direction: column;
    gap: 24px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  }

  .pricing-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-primary);
    box-shadow: 0 12px 40px rgba(0, 115, 207, 0.12);
  }

  .pricing-card.featured {
    background: linear-gradient(135deg, #0073CF 0%, #0056A3 100%);
    border-color: transparent;
    transform: scale(1.05);
    box-shadow: 0 20px 60px rgba(0, 115, 207, 0.3);
    color: white;
  }

  .pricing-card.featured:hover {
    transform: scale(1.05) translateY(-4px);
  }

  .pricing-card-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    padding: 6px 20px;
    background: var(--color-accent);
    color: var(--color-text);
    border-radius: 100px;
    font-size: 13px;
    font-weight: 700;
    white-space: nowrap;
    box-shadow: 0 4px 16px rgba(255, 212, 0, 0.3);
  }

  .pricing-card-header {
    text-align: center;
  }

  .plan-emoji {
    font-size: 36px;
    display: block;
    margin-bottom: 8px;
  }

  .plan-name {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 4px;
  }

  .plan-description {
    font-size: 14px;
    opacity: 0.65;
  }

  .pricing-card-promo {
    text-align: center;
    padding: 16px 0;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .featured .pricing-card-promo {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .promo-badge {
    font-size: 12px;
    font-weight: 800;
    color: var(--color-danger);
    background: rgba(227, 6, 19, 0.08);
    padding: 6px 16px;
    border-radius: 4px;
    border: 1px dashed var(--color-danger);
    display: inline-block;
  }

  .featured .promo-badge {
    color: var(--color-accent);
    background: rgba(255, 212, 0, 0.1);
    border-color: var(--color-accent);
  }

  .pricing-cta {
    display: block;
    text-align: center;
    padding: 16px 24px;
    border-radius: var(--radius-sm);
    font-size: 14px;
    font-weight: 800;
    transition: all 0.3s ease;
    background: #25D366;
    color: white;
    box-shadow: 0 4px 12px rgba(37, 211, 102, 0.2);
  }

  .pricing-cta:hover {
    background: #20BA5C;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(37, 211, 102, 0.4);
    color: white;
  }

  .pricing-response-note {
    font-size: 13px;
    color: #25D366;
    font-weight: 600;
    text-align: center;
    display: block;
    margin-top: -16px;
  }

  .pricing-info {
    margin-top: 40px;
    padding: 20px 28px;
    background: rgba(0, 115, 207, 0.04);
    border: 1px solid rgba(0, 115, 207, 0.1);
    border-radius: var(--radius);
    text-align: center;
  }

  .pricing-info p {
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  @media (max-width: 1024px) {
    .pricing-grid {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin: 0 auto;
    }

    .pricing-card.featured {
      transform: none;
    }

    .pricing-card.featured:hover {
      transform: translateY(-4px);
    }
  }
</style>
