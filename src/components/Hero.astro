---
// arquivo: src/components/Hero.astro
---

<section class="hero" id="hero">
  <div class="hero-grain"></div>
  <div class="hero-content container">
    <div class="hero-badge animate-hero" style="--delay: 0s;">
      🎮 Promoção Maio · Pulando Demais
    </div>

    <h1 class="hero-headline animate-hero" style="--delay: 0.1s;">
      Monte a Melhor<br />
      <span class="highlight">Festa de Jogos!</span>
    </h1>

    <p class="hero-subtitle animate-hero" style="--delay: 0.2s;">
      Aluguel de mesas de jogos e jogos eletrônicos para festas e eventos no Rio de Janeiro. 
      Totó, sinuca, fliperama, karaokê e muito mais. Entrega, montagem e monitoria inclusos!
    </p>

    <div class="hero-buttons animate-hero" style="--delay: 0.3s;">
      <a
        href="https://wa.me/5521964370625?text=Ol%C3%A1!%20Vim%20pelo%20Google%20e%20quero%20usar%20o%20cupom:%20OFERTA-MAIO-PD%20para%20garantir%20o%20desconto%20da%20semana!"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-primary"
        aria-label="Solicitar orçamento pelo WhatsApp"
      >
        Solicitar Orçamento →
      </a>
      <a href="#catalogo" class="btn btn-secondary">
        Ver Jogos Disponíveis
      </a>
    </div>

    <div class="hero-social-proof animate-hero" style="--delay: 0.4s;">
      <div class="avatars">
        <span class="avatar" style="background: var(--color-accent);">🎯</span>
        <span class="avatar" style="background: var(--color-primary);">🎮</span>
        <span class="avatar" style="background: var(--color-danger);">🏆</span>
      </div>
      <span class="social-text">Mais de 5.000 festas realizadas no RJ</span>
    </div>

    <div class="hero-card animate-hero" style="--delay: 0.5s;">
      <div class="card-glow"></div>
      <span class="card-number">98%</span>
      <span class="card-label">dos clientes recomendam</span>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: linear-gradient(135deg, #0056A3 0%, #0073CF 30%, #003d73 60%, #0056A3 100%);
    background-size: 300% 300%;
    animation: gradientShift 12s ease infinite;
    padding: clamp(80px, 10vw, 120px) 0;
  }

  .hero-grain {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-size: 128px 128px;
    pointer-events: none;
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 20px;
    border-radius: 100px;
    border: 1.5px solid var(--color-accent);
    background: rgba(255, 212, 0, 0.1);
    color: var(--color-accent);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.5px;
    backdrop-filter: blur(8px);
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(40px, 8vw, 80px);
    font-weight: 800;
    line-height: 1.05;
    color: var(--color-text-light);
    max-width: 800px;
  }

  .highlight {
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-dark) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: clamp(15px, 2.5vw, 19px);
    color: rgba(255, 255, 255, 0.8);
    max-width: 580px;
    line-height: 1.7;
    font-weight: 300;
  }

  .hero-buttons {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 8px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    border-radius: var(--radius-sm);
    font-size: 16px;
    font-weight: 600;
    transition: all 0.3s ease;
    letter-spacing: 0.3px;
  }

  .btn-primary {
    background: var(--color-accent);
    color: var(--color-text);
    box-shadow: 0 4px 20px rgba(255, 212, 0, 0.3);
  }

  .btn-primary:hover {
    background: var(--color-accent-dark);
    transform: translateY(-2px);
    box-shadow: 0 6px 30px rgba(255, 212, 0, 0.5);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text-light);
    border: 1.5px solid rgba(255, 255, 255, 0.3);
  }

  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: rgba(255, 212, 0, 0.05);
    transform: translateY(-2px);
  }

  .hero-social-proof {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 8px;
  }

  .avatars {
    display: flex;
  }

  .avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    border: 2px solid rgba(255, 255, 255, 0.2);
    margin-left: -8px;
  }

  .avatar:first-child {
    margin-left: 0;
  }

  .social-text {
    color: rgba(255, 255, 255, 0.65);
    font-size: 14px;
    font-weight: 400;
  }

  .hero-card {
    position: relative;
    margin-top: 16px;
    padding: 20px 32px;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    gap: 12px;
    animation: float 4s ease-in-out infinite;
    animation-delay: 1s;
  }

  .card-glow {
    position: absolute;
    inset: -2px;
    border-radius: var(--radius);
    background: linear-gradient(135deg, rgba(0, 115, 207, 0.3), rgba(255, 212, 0, 0.3));
    z-index: -1;
    filter: blur(12px);
    opacity: 0.5;
  }

  .card-number {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 800;
    color: var(--color-accent);
  }

  .card-label {
    color: rgba(255, 255, 255, 0.7);
    font-size: 14px;
    font-weight: 400;
  }

  /* ===== Staggered Animation ===== */
  .animate-hero {
    opacity: 0;
    transform: translateY(30px);
    animation: fadeUp 0.7s ease forwards;
    animation-delay: var(--delay);
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 100svh;
      padding: 100px 0 60px;
    }

    .hero-buttons {
      flex-direction: column;
      width: 100%;
      padding: 0 8px;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }

    .hero-social-proof {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
